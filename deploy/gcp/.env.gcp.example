# Core sending
EMAIL_SEND_MODE=gmail_api
CLOUD_SEND_ENABLED=true
CLOUD_AUTO_DEPLOY_ON_COMPLETE=false
CLOUD_ENVIRONMENT=gcp_vm

# Google Cloud Storage transport
GCS_BUCKET=your-gcs-bucket-name
GCS_RUNS_PREFIX=runs
GCS_MANIFESTS_PREFIX=manifests
GCS_INFLIGHT_PREFIX=inflight
GCS_PROCESSED_PREFIX=processed
GCS_FAILED_PREFIX=failed
CLOUD_WORKER_POLL_SECONDS=60
CLOUD_WORKER_ALERT_WEBHOOK=
# Recommended fixed recovery path on the VM:
# SOLAR_SECRET_SOURCE_DIR=/home/<vm-user>/solar-secrets/gmail
SOLAR_SECRET_SOURCE_DIR=
# Optional Secret Manager mode:
# SOLAR_GMAIL_CLIENT_SECRET_NAME=solar-gmail-client-secret
# SOLAR_GMAIL_TOKEN_SECRET_NAME=solar-gmail-token
SOLAR_GMAIL_CLIENT_SECRET_NAME=
SOLAR_GMAIL_TOKEN_SECRET_NAME=
REPO_BRANCH=main

# Gmail sender identity
SENDER_NAME=Wayne
SENDER_TITLE=Sales Development Representative
SMTP_FROM_NAME=Wayne
REPLY_TO_EMAIL=

# Gmail API / OAuth runtime
# Put config/gmail_client_secret.json and config/gmail_token.json on the VM,
# or fetch them from Secret Manager before starting the worker.

# General pipeline settings you already use locally
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
GOOGLE_MAPS_API_KEY=
APOLLO_API_KEY=
HUNTER_API_KEY=
LLM_PROVIDER=
LLM_MODEL=
EMAIL_GEN_PROVIDER=openrouter
EMAIL_GEN_MODEL=anthropic/claude-3.5-haiku
EMAIL_GEN_FALLBACK_MODEL=openai/gpt-4o-mini
