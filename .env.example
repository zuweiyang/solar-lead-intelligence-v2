# --- API Keys ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_MAPS_API_KEY=
APOLLO_API_KEY=
HUNTER_API_KEY=
OPENROUTER_API_KEY=
LLM_PROVIDER=
LLM_MODEL=
EMAIL_GEN_PROVIDER=openrouter
EMAIL_GEN_MODEL=anthropic/claude-3.5-haiku
EMAIL_GEN_FALLBACK_MODEL=openai/gpt-4o-mini

# --- Sender identity ---
SENDER_NAME=Wayne
SENDER_TITLE=Sales Development Representative

# --- SMTP / legacy email settings ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_ADDRESS=
EMAIL_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Wayne
REPLY_TO_EMAIL=

# --- Send behavior ---
EMAIL_SEND_MODE=dry_run
SEND_WINDOW_START=8
SEND_WINDOW_END=18
SEND_WINDOW_SLOTS=09:00-12:00,14:00-16:00
DAILY_EMAIL_LIMIT=100
BATCH_SIZE=100
SCRAPE_DELAY_SECONDS=1.0
CRAWL_DELAY_SECONDS=1.0

# --- Gmail API throttling ---
GMAIL_API_MIN_SEND_INTERVAL_SECONDS=2.0
GMAIL_API_MAX_RETRIES=5
GMAIL_API_BACKOFF_BASE_SECONDS=1.0
GMAIL_API_BACKOFF_MAX_SECONDS=32.0
GMAIL_API_ENABLE_JITTER=true
SEND_PACING_MIN_SECONDS=45
SEND_PACING_MAX_SECONDS=180
SEND_HOURLY_LIMIT=20

# --- Cloud send deployment ---
CLOUD_SEND_ENABLED=false
CLOUD_AUTO_DEPLOY_ON_COMPLETE=false
CLOUD_ENVIRONMENT=local
GCS_BUCKET=
GCS_RUNS_PREFIX=runs
GCS_MANIFESTS_PREFIX=manifests
GCS_PROCESSED_PREFIX=processed
GCS_FAILED_PREFIX=failed
CLOUD_WORKER_POLL_SECONDS=60
CLOUD_WORKER_ALERT_WEBHOOK=

# --- Tracking / follow-up ---
TRACKING_BASE_URL=http://localhost:5000
FOLLOWUP_MAX_STAGE=3
FOLLOWUP_1_DELAY_DAYS=3
FOLLOWUP_2_DELAY_DAYS=7
FOLLOWUP_3_DELAY_DAYS=14

# --- Email verification ---
EMAIL_VERIFIER_PROVIDER=hunter
EMAIL_VERIFIER_LIVE=false

# --- Deliverability breaker thresholds ---
BREAKER_HARD_BOUNCE_RATE=0.03
BREAKER_INVALID_RATE=0.02
BREAKER_PROVIDER_FAILURE_RATE=0.05
BREAKER_UNSUBSCRIBE_RATE=0.005
BREAKER_SPAM_RATE_WARNING=0.001
BREAKER_SPAM_RATE_CRITICAL=0.003
